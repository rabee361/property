  "about": {
    "section_title": "\u0645\u0646 \u0646\u062d\u0646",
    "text_1": "\u0646\u062d\u0646 \u0646\u0639\u064a\u062f \u062a\u0639\u0631\u064a\u0641 \u0645\u0641\u0647\u0648\u0645 \u0627\u0644\u0639\u0642\u0627\u0631\u0627\u062a \u0645\u0646 \u062e\u0644\u0627\u0644 \u0631\u0628\u0637 \u0627\u0644\u0623\u0634\u062e\u0627\u0635 \u0628\u0645\u0646\u0627\u0632\u0644 \u0623\u062d\u0644\u0627\u0645\u0647\u0645 \u0648\u0627\u0644\u0645\u0633\u0627\u062d\u0627\u062a \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0627\u0644\u0645\u062a\u0645\u064a\u0632\u0629. \u0641\u0631\u064a\u0642\u0646\u0627 \u0645\u0646 \u0627\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646 \u0627\u0644\u0645\u062a\u0645\u0631\u0633\u064a\u0646 \u0645\u0643\u0631\u0633 \u0644\u062a\u0648\u062c\u064a\u0647\u0643 \u0639\u0628\u0631 \u062a\u0639\u0642\u064a\u062f\u0627\u062a \u0627\u0644\u0633\u0648\u0642.",
    "text_2": "\u0645\u0639 \u0627\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u0627\u0644\u062b\u0642\u0629 \u0648\u0627\u0644\u0634\u0641\u0627\u0641\u064a\u0629 \u0648\u0627\u0644\u062d\u0644\u0648\u0644 \u0627\u0644\u0645\u0635\u0645\u0645\u0629 \u062e\u0635\u064a\u0635\u0627\u064b\u060c \u0646\u0641\u062e\u0631 \u0628\u062a\u0642\u062f\u064a\u0645 \u0645\u062c\u0645\u0648\u0639\u0629 \u062d\u0635\u0631\u064a\u0629 \u0645\u0646 \u0627\u0644\u0639\u0642\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0644\u0628\u064a \u0623\u0639\u0644\u0649 \u0645\u0639\u0627\u064a\u064a\u0631 \u0627\u0644\u0641\u062e\u0627\u0645\u0629 \u0648\u0627\u0644\u0631\u0627\u062d\u0629."
